{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for the leaderboard and community.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalQuestions": { "type": "integer" },
        "totalHours": { "type": "number" },
        "streak": { "type": "integer" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "totalQuestions", "totalHours", "streak"]
    },
    "DashboardSettings": {
      "title": "Dashboard Settings",
      "description": "User-specific dashboard configuration.",
      "type": "object",
      "properties": {
        "customExams": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "date": { "type": "string", "format": "date-time" }
            }
          }
        },
        "selectedExam": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "label": { "type": "string" },
            "date": { "type": "string", "format": "date-time" }
          }
        },
        "targetHours": { "type": "number" }
      }
    },
    "DailyTargets": {
      "title": "Daily Targets",
      "description": "List of daily goals for the user.",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "SubjectChecklist": {
      "title": "Subject Checklist",
      "description": "Progress tracking for subjects and chapters.",
      "type": "object",
      "properties": {
        "subjects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "color": { "type": "string" },
              "font": { "type": "string" },
              "chapters": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "completed": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "TimerState": {
      "title": "Timer State",
      "description": "Current state of the study timer.",
      "type": "object",
      "properties": {
        "isRunning": { "type": "boolean" },
        "startTime": { "type": "number" },
        "accumulatedSeconds": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Study statistics for a specific day.",
      "type": "object",
      "properties": {
        "studySeconds": { "type": "number" },
        "questionsSolved": { "type": "integer" },
        "subjectSeconds": { "type": "object" },
        "subjectQuestions": { "type": "object" },
        "isMockTest": { "type": "boolean" },
        "mockTestCompleted": { "type": "boolean" },
        "mockTestMarks": { "type": "string" },
        "date": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Aggregated statistics for all users.",
      "type": "object",
      "properties": {
        "totalStudents": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "totalHours": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "A single activity log entry.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "action": { "type": "string" },
        "type": { "type": "string", "enum": ["questions", "hours"] },
        "value": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Community Post",
      "description": "A post in the community feed.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "category": { "type": "string" },
        "community": { "type": "string", "enum": ["jee", "neet"] },
        "likes": { "type": "array", "items": { "type": "string" } },
        "reactions": { "type": "object" },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "uid": { "type": "string" },
              "displayName": { "type": "string" },
              "photoURL": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Direct Message",
      "description": "A direct message or doubt sent between friends.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "doubt"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "participants", "senderId", "receiverId", "text", "type", "read"]
    },
    "Note": {
      "title": "Note",
      "description": "A quick note taken by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "subject": { "type": "string" },
        "chapter": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "goal"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "content", "createdAt", "type"]
    }
  },
  "firestore": {
    "/users/{uid}/settings/dashboard": {
      "schema": "DashboardSettings",
      "description": "Dashboard configuration for a user."
    },
    "/users/{uid}/data/dailyTargets": {
      "schema": "DailyTargets",
      "description": "Daily targets for a user."
    },
    "/users/{uid}/data/checklist": {
      "schema": "SubjectChecklist",
      "description": "Subject checklist for a user."
    },
    "/users/{uid}/data/timer": {
      "schema": "TimerState",
      "description": "Timer state for a user."
    },
    "/users/{uid}/dailyStats/{date}": {
      "schema": "DailyStats",
      "description": "Daily study statistics for a user."
    },
    "/users/{uid}/notes/{noteId}": {
      "schema": "Note",
      "description": "Notes for a user."
    },
    "/leaderboard/{uid}": {
      "schema": "User",
      "description": "Leaderboard entry for a user."
    },
    "/stats/global": {
      "schema": "GlobalStats",
      "description": "Global statistics for the application."
    },
    "/activity/{id}": {
      "schema": "Activity",
      "description": "Activity log entry."
    },
    "/posts/{id}": {
      "schema": "Post",
      "description": "Community post."
    },
    "/messages/{id}": {
      "schema": "Message",
      "description": "Direct message or doubt."
    }
  }
}
