rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (required)
    //   - photoURL: string (required)
    //   - totalQuestions: number (required)
    //   - totalHours: number (required)
    //   - streak: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: activity
    // Document ID: {activityId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - action: string (required)
    //   - type: string (required, enum: ['questions', 'hours'])
    //   - value: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - text: string (required)
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (required)
    //   - category: string (required)
    //   - community: string (required, enum: ['jee', 'neet'])
    //   - likes: array (required)
    //   - reactions: map (optional)
    //   - comments: array (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Sub-paths:
    //   - settings/dashboard: Dashboard configuration
    //   - data/dailyTargets: Daily goals
    //   - data/checklist: Subject/Chapter progress
    //   - data/timer: Current timer state
    //   - dailyStats/{date}: Daily study statistics
    //
    // Collection: stats
    // Document ID: global
    // Fields:
    //   - totalStudents: number (required)
    //   - totalQuestions: number (required)
    //   - totalHours: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - toUid: string (required)
    //   - fromUid: string (required)
    //   - fromName: string (required)
    //   - fromPhoto: string (optional)
    //   - type: string (required, enum: ['reaction', 'reply'])
    //   - postId: string (required)
    //   - content: string (required)
    //   - read: bool (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "bablasaur19@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Helpers
    // ===============================================================

    function isValidNotification(data) {
      return data.keys().hasAll(['toUid', 'fromUid', 'fromName', 'type', 'postId', 'content', 'read', 'createdAt']) &&
             data.toUid is string && isValidId(data.toUid) &&
             data.fromUid == request.auth.uid &&
             data.fromName is string && data.fromName.size() <= 100 &&
             data.type in ['reaction', 'reply', 'comment_reply', 'post_reply'] &&
             data.read == false &&
             data.content is string && data.content.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidPost(data, isUpdate) {
      let requiredFields = ['text', 'uid', 'displayName', 'photoURL', 'category', 'community', 'likes', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.text is string && data.text.size() <= 5000 &&
             data.uid == (isUpdate ? existing().uid : request.auth.uid) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.category is string &&
             data.community is string && data.community.size() <= 50 &&
             data.likes is list && data.likes.size() <= 10000 &&
             (isUpdate ? data.createdAt == existing().createdAt : data.createdAt == request.time);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'participants', 'senderId', 'receiverId', 'text', 'type', 'read', 'createdAt']) &&
             data.chatId is string &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.senderId == request.auth.uid &&
             data.receiverId is string && isValidId(data.receiverId) &&
             data.text is string && data.text.size() <= 3000 &&
             data.type in ['text', 'doubt'] &&
             data.read == false &&
             data.createdAt == request.time;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['uid', 'displayName', 'action', 'type', 'value', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.action is string && data.action.size() <= 200 &&
             data.type in ['questions', 'hours'] &&
             data.value is number &&
             data.createdAt == request.time;
    }

    function isValidLeaderboard(data, isUpdate) {
      let requiredFields = ['displayName', 'photoURL', 'totalQuestions', 'totalHours', 'streak', 'lastUpdated'];
      return (isUpdate || data.keys().hasAll(requiredFields)) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.totalQuestions is number &&
             data.totalHours is number &&
             data.streak is number &&
             (isUpdate ? (data.lastUpdated == existing().lastUpdated || data.lastUpdated == request.time) : data.lastUpdated == request.time);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /notifications/{notificationId} {
      allow read, delete: if isAuthenticated() && resource.data.toUid == request.auth.uid;
      allow update: if isAuthenticated() && 
                      resource.data.toUid == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated() && isValidNotification(incoming());
    }

    match /leaderboard/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && isValidLeaderboard(incoming(), false);
      allow update: if (isOwner(userId) && isValidLeaderboard(incoming(), true)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activity/{activityId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && isValidActivity(incoming());
      allow delete: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
      allow update: if isAdmin();
    }

    match /posts/{postId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && isValidPost(incoming(), false);
      allow update: if isAuthenticated() && (
        // Action: Like/React/Comment
        (incoming().diff(existing()).affectedKeys().hasAny(['likes', 'reactions', 'comments'])) ||
        // Action: Edit
        (isOwner(existing().uid) && isValidPost(incoming(), true))
      );
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        // Action: Friend Link (Mutual)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['friends']) &&
          isValidFriendUpdate()
        )
      );
      allow delete: if isAdmin();

      match /{allPaths=**} {
        allow read: if isOwner(userId) || isAdmin() || (
          isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(userId)) &&
          request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get('friends', [])
        );
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    function isValidFriendUpdate() {
      let hasFriends = 'friends' in resource.data && resource.data.friends is list;
      let oldFriends = hasFriends ? resource.data.friends : [];
      let newFriends = request.resource.data.friends;
      
      return newFriends is list &&
             (
               (newFriends.size() == oldFriends.size() + 1 && newFriends.removeAll(oldFriends) == [request.auth.uid]) ||
               (newFriends.size() == oldFriends.size() && newFriends.hasAll(oldFriends) && oldFriends.hasAll(newFriends)) ||
               (newFriends.size() == oldFriends.size() - 1 && oldFriends.removeAll(newFriends) == [request.auth.uid])
             );
    }

    match /stats/{statId} {
      allow get, list: if true;
      allow update: if isAuthenticated() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['totalStudents', 'totalQuestions', 'totalHours', 'lastUpdated']) &&
        incoming().lastUpdated == request.time;
      allow create, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid == (resource.data.receiverId) ||
        request.auth.uid == (resource.data.senderId)
      );
      allow create: if isAuthenticated() && isValidMessage(incoming());
      allow update: if isAuthenticated() && 
                      request.auth.uid == resource.data.receiverId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if (isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid)) || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
