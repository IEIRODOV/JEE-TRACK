rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (required)
    //   - photoURL: string (required)
    //   - totalQuestions: number (required)
    //   - totalHours: number (required)
    //   - streak: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: activity
    // Document ID: {activityId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - action: string (required)
    //   - type: string (required, enum: ['questions', 'hours'])
    //   - value: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - text: string (required)
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (required)
    //   - category: string (required)
    //   - community: string (required, enum: ['jee', 'neet'])
    //   - likes: array (required)
    //   - reactions: map (optional)
    //   - comments: array (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Sub-paths:
    //   - settings/dashboard: Dashboard configuration
    //   - data/dailyTargets: Daily goals
    //   - data/checklist: Subject/Chapter progress
    //   - data/timer: Current timer state
    //   - dailyStats/{date}: Daily study statistics
    //
    // Collection: stats
    // Document ID: global
    // Fields:
    //   - totalStudents: number (required)
    //   - totalQuestions: number (required)
    //   - totalHours: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - toUid: string (required)
    //   - fromUid: string (required)
    //   - fromName: string (required)
    //   - fromPhoto: string (optional)
    //   - type: string (required, enum: ['reaction', 'reply'])
    //   - postId: string (required)
    //   - content: string (required)
    //   - read: bool (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "bablasaur19@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isValidNotification() {
      let data = request.resource.data;
      return hasRequiredFields(['toUid', 'fromUid', 'fromName', 'type', 'postId', 'content', 'read', 'createdAt']) &&
             data.toUid is string &&
             data.fromUid is string &&
             data.fromName is string &&
             data.type in ['reaction', 'reply'] &&
             data.read == false &&
             data.content is string &&
             data.content.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Notifications: Recipient only can read/update/delete, authenticated can create
    match /notifications/{notificationId} {
      allow read, delete: if isAuthenticated() && resource.data.toUid == request.auth.uid;
      allow update: if isAuthenticated() && 
                      resource.data.toUid == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated() && 
                      request.resource.data.fromUid == request.auth.uid &&
                      isValidNotification();
    }

    // Leaderboard: Publicly readable, owner/admin writable
    match /leaderboard/{userId} {
      allow get, list: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // Activity: Publicly readable, owner/admin creatable
    match /activity/{activityId} {
      allow get, list: if true;
      allow create: if (isAuthenticated() && request.resource.data.uid == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Posts: Publicly readable, owner/admin creatable
    match /posts/{postId} {
      allow get, list: if true;
      allow create: if (isAuthenticated() && request.resource.data.uid == request.auth.uid) || isAdmin();
      allow update: if isAuthenticated() && (
        // Allow users to like/unlike or react (only update specific keys)
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'reactions', 'comments']) ||
        // Allow owner to edit their post
        (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid)
      );
      allow delete: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    // Private User Data: Owner/Admin only
    match /users/{userId} {
      // Allow authenticated users to read profiles (for friend search and viewing friend stats)
      allow read: if isAuthenticated();
      // Allow owner/admin full write
      allow write: if isOwner(userId) || isAdmin();
      
      // Allow anyone to add themselves to a user's friend list (mutual link)
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
          request.resource.data.friends.hasAll(resource.data.friends || []) &&
          request.resource.data.friends.size() == (resource.data.friends || []).size() + 1 &&
          request.resource.data.friends.hasAny([request.auth.uid])
        )
      );

      match /{allPaths=**} {
        allow read: if isOwner(userId) || isAdmin() || (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.friends);
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Stats: Publicly readable, authenticated incrementable
    match /stats/{statId} {
      allow get, list: if true;
      allow update: if isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalStudents', 'totalQuestions', 'totalHours', 'lastUpdated']);
      allow create: if isAdmin();
    }

    // Messages: Participants only
    match /messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow update: if isAuthenticated() && 
                      request.auth.uid == resource.data.receiverId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated() && 
                      request.resource.data.senderId == request.auth.uid &&
                      hasRequiredFields(['chatId', 'participants', 'senderId', 'receiverId', 'text', 'type', 'read', 'createdAt']) &&
                      request.resource.data.chatId is string &&
                      request.resource.data.participants is list &&
                      request.resource.data.participants.size() == 2 &&
                      request.auth.uid in request.resource.data.participants &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() <= 2000 &&
                      request.resource.data.type in ['text', 'doubt'] &&
                      request.resource.data.read == false &&
                      request.resource.data.createdAt == request.time;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
